# Port to expose the service on
PORT=5001

# Address to bind the Flask server to
BIND_HOST=0.0.0.0

# Secret key for Flask sessions (generate a secure random one)
SECRET_KEY=default-secret-key-change-me-please

# Node API Token used to secure node-to-auth-server communication (generate a secure random one)
NODE_API_TOKEN=default-token-change-me-please

# Default admin password for clean installations (automatically created on first start)
ADMIN_PASSWORD=admin123
