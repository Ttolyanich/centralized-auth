# ==============================================================================
# Шаблон конфигурации окружения для Centralized Auth Server
# Переименуйте этот файл в .env и настройте параметры ниже
# ==============================================================================

# Порт для запуска веб-сервера Flask (по умолчанию 5001)
PORT=5001

# Хост / интерфейс для прослушивания (0.0.0.0 — слушать все интерфейсы)
BIND_HOST=0.0.0.0

# Секретный ключ для подписи сессий Flask (обязательно смените в продакшне)
# Для генерации случайного ключа выполните команду:
# openssl rand -hex 16
SECRET_KEY=default-secret-key-change-me-please

# Токен для авторизации запросов от доверенных нод (должен совпадать на всех нодах)
# Для генерации случайного токена выполните команду:
# openssl rand -hex 16
NODE_API_TOKEN=default-token-change-me-please

# Пароль по умолчанию для администратора 'admin' (генерируется при первом запуске)
ADMIN_PASSWORD=admin123
